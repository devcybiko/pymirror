{
  "pmdb": {
    "url": "sqlite:///$HOME/pymirror.db"
  },
  "secrets": "$HOME/.secrets",
  "tasks": [
    {
      "class": "time",
      "name": "time",
      "cron": "*:*:00"
    },
    {
      "class": "turo_task",
      "name": "turo_task",
      "cron": "*:15:00",
      "from_file": "greg@GregsM4MacMini:turo.sqlite",
      "to_file": "/home/pymirror/turo.sqlite",
      "cp_command": "scp {from_file} {to_file}"
    }
  ]
}
