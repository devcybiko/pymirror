{
    "module": {
        "class": "plot",
        "name": "plot",
        "text_color": "#fff",
        "text_bg_color": null,
        "position": "0.01,0.65,0.99,0.94",
        "font_size": 16,
        "color": "#fff",
        "bg_color": "#000",
        "text_color": "#fff",
        "text_bg_color": "#333",
    },
    "plot": {
        "refresh_time": "60s",
        "database": "$HOME/turo.sqlite",
        "sql": "SELECT trip_start, total_earnings FROM trips WHERE vehicle_nickname='cx5' AND trip_status in ('Completed', 'In-progress', 'Booked') ORDER BY trip_start",
        "x_axis": {
          "column": "trip_date",
          "label": "Date",
          "format": "%Y-%m-%d",
        },
        "y_axis": [
            {
                "column": "total_earnings",
                "label": "Earnings",
                "color": "#fff",
            }
        ]
    }
}